{
  "name": "next-after-avenue",
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.0",
  "private": true,
  "scripts": {
    "scaffold": "bash scripts/scaffold.sh",
    "dev": "NODE_OPTIONS='--inspect' next dev -p 3005 --webpack",
    "dev:webpack": "NODE_OPTIONS='--inspect' next dev -p 3005 --webpack",
    "build": "next build && make sitemap",
    "build:analyze": "next experimental-analyze && make sitemap",
    "build:analyze:legacy": "ANALYZE=true next build && make sitemap",
    "start": "next start -p 3005",
    "export": "next export",
    "tsc:ci": "tsc --strict",
    "lint": "biome check",
    "lint:ci": "biome ci --reporter=github",
    "lint:fix": "biome check --fix",
    "lint:changed": "biome check --changed --since origin/main --no-errors-on-unmatched --verbose --write --diagnostic-level=error",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "lint:all": "pnpm lint:changed && pnpm lint:css:fix",
    "format": "biome format --write .",
    "test:ci": "jest --passWithNoTests",
    "types:contentful": "export $(cat .env.local | sed '/^#/d; s/[$\"]//g'); cf-content-types-generator -s $CONTENTFUL_SPACE_ID -t $CONTENTFUL_CMA_TOKEN -o src/contentful/types -r -g && biome format --write src/contentful/types",
    "knip": "knip",
    "knip:ci": "knip --no-progress"
  },
  "dependencies": {
    "@contentful/rich-text-plain-text-renderer": "^17.2.1",
    "@contentful/rich-text-react-renderer": "^16.2.1",
    "@contentful/rich-text-types": "^17.2.7",
    "@jest/types": "^30.4.1",
    "@next/third-parties": "^16.2.6",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/react-query": "^5.100.14",
    "classnames": "^2.5.1",
    "contentful": "^11.12.3",
    "html-react-parser": "^6.1.2",
    "next": "^16.2.6",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^11.3.0",
    "react": "^19.2.6",
    "react-aria": "^3.49.0",
    "react-dom": "^19.2.6",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.77.0",
    "react-intersection-observer": "^10.0.3",
    "react-player": "^3.4.0",
    "resend": "6.12.4",
    "safe-json-stringify": "^1.2.0",
    "schema-dts": "^2.0.0",
    "sonner": "^2.0.7",
    "tslib": "^2.8.1",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@faker-js/faker": "^10.4.0",
    "@jest/globals": "^30.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/safe-json-stringify": "^1.1.5",
    "cf-content-types-generator": "^3.0.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.15.0",
    "stylelint": "^17.12.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "webpack-bundle-analyzer": "^5.3.0"
  }
}
