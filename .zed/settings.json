{
  "lsp": {
    "biome": {
      "binary": {
        "arguments": [
          "lsp-proxy"
        ],
        "path": "node_modules/.bin/biome",
      },
      "settings": {
        "config_path": "biome.json",
        "require_config_file": true,
      },
    },
  },
}
